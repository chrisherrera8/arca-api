# Database
DATABASE_URL=postgresql+asyncpg://arca:arca@localhost:5432/arca

# Auth
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
